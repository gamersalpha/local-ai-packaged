# Auto detect text files and perform LF normalization
* text=auto

# Force LF line endings for shell scripts (prevents CRLF issues in Docker/Linux)
*.sh text eol=lf
# Dockerfiles and entrypoints
Dockerfile* text eol=lf
*.dockerfile text eol=lf
# Config files used by Linux containers
Caddyfile text eol=lf
*.conf text eol=lf
*.yml text eol=lf
*.yaml text eol=lf
